@model List<BlogProject.Models.BlogPost>
@{
    ViewData["Title"] = "Manage Posts";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4">Manage Blog Posts</h2>

<a href="/Admin/Create" class="btn btn-success mb-3">+ New Post</a>

<table class="table table-bordered">
    <thead class="table-light">
        <tr>
            <th>Title</th>
            <th style="width: 200px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var post in Model)
        {
            <tr>
                <td>@post.Title</td>
                <td>
                    <a href="/Admin/Edit/@post.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a href="/Admin/Delete/@post.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
